            "\t<button type=\"button\" class=\"swiper-button swiper-button-prev\" aria-label=\"이전 슬라이드\"><i class=\"svg-icon ico-angle left\" aria-hidden=\"true\"></i></button>",
            "\t<div class=\"swiper-autoplay\">",
            "\t\t<button type=\"button\" class=\"swiper-button-pause active\" data-swiper=\"${2:sponsor}\" aria-label=\"일시정지\"><i class=\"svg-icon ico-pause\" aria-hidden=\"true\"></i></button>",
            "\t\t<button type=\"button\" class=\"swiper-button-start\" data-swiper=\"${2:sponsor}\" aria-label=\"재생\"><i class=\"svg-icon ico-play\" aria-hidden=\"true\"></i></button>",
            "\t</div>",
            "\t<button type=\"button\" class=\"swiper-button swiper-button-next\" aria-label=\"다음 슬라이드\"><i class=\"svg-icon ico-angle right\" aria-hidden=\"true\"></i></button>",
