    "테이블": {
        "prefix": [
            "table",
            "테이블"
        ],
        "body": [
            "<div class=\"table responsive\">",
            "\t<table>",
            "\t\t<caption>${1:표 제목}</caption>",
            "\t\t<colgroup>",
            "\t\t\t<col span=\"4\">",
            "\t\t</colgroup>",
            "\t\t<thead>",
            "\t\t\t<tr>",
            "\t\t\t\t<th scope=\"col\"></th>",
            "\t\t\t\t<th scope=\"col\"></th>",
            "\t\t\t\t<th scope=\"col\"></th>",
            "\t\t\t\t<th scope=\"col\"></th>",
            "\t\t\t</tr>",
            "\t\t</thead>",
            "\t\t<tbody>",
            "\t\t\t<tr>",
            "\t\t\t\t<th scope=\"row\"></th>",
            "\t\t\t\t<td></td>",
            "\t\t\t\t<td></td>",
            "\t\t\t\t<td></td>",
            "\t\t\t</tr>",
            "\t\t</tbody>",
            "\t</table>",
            "</div>"
